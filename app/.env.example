# Copy this file to .env and fill in your own values. .env is gitignored --
# never commit real RPC URLs/API keys.

# Defaults to the local validator (http://127.0.0.1:8899) if unset.
VITE_RPC_URL=http://127.0.0.1:8899

# "devnet" or "mainnet" -- picks which Raydium CPMM program addresses the
# app talks to. Defaults to "devnet" if unset.
VITE_CLUSTER=devnet
