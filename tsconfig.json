{
  "compilerOptions": {
    "types": ["mocha", "chai", "node"],
    "typeRoots": ["./node_modules/@types"],
    "target": "es2019",
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
